PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=production
PLAID_REDIRECT_URI=https://your-public-app-url/plaid/oauth
PLAID_TOKEN_ENCRYPTION_KEY=a_random_32_byte_hex_string

OPENAI_API_KEY=your_openai_api_key

# Hosted Vercel deployments should use the Supabase transaction pooler URL.
# For local debugging, the direct db.<project-ref>.supabase.co:5432 connection can be more stable.
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-1-your-region.pooler.supabase.com:6543/postgres
DATABASE_POOL_MAX=5
DATABASE_STATEMENT_TIMEOUT_MS=15000
DATABASE_LOCK_TIMEOUT_MS=5000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Required for deleting Supabase Auth users during self-service account deletion.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional:
# PUBLIC_PROFILE_ONLY=1
# CRON_SECRET=a_random_secret_for_vercel_cron_authorization
# PLAID_BACKGROUND_SYNC_STALE_HOURS=12
# PLAID_BACKGROUND_SYNC_LIMIT=10
# PLAID_WEBHOOK_SECRET=a_random_secret_appended_to_the_plaid_webhook_url
# PLAID_WEBHOOK_URL=https://your-public-app-url/api/plaid/webhook?secret=your_secret
# ERROR_ALERT_WEBHOOK_URL=https://your-alert-destination.example/webhook
# ERROR_ALERT_WEBHOOK_TOKEN=optional_bearer_token_for_the_alert_destination
