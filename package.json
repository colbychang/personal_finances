{
  "name": "personal-finances",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "vercel-build": "sh -c 'if [ -n \"$PUBLIC_PROFILE_ONLY\" ]; then export PUBLIC_PROFILE_ONLY; elif [ -n \"$DATABASE_URL\" ] && [ -n \"$NEXT_PUBLIC_SUPABASE_URL\" ] && [ -n \"$NEXT_PUBLIC_SUPABASE_ANON_KEY\" ]; then export PUBLIC_PROFILE_ONLY=0; else export PUBLIC_PROFILE_ONLY=1; fi; next build'",
    "start": "next start -p 3000",
    "lint": "eslint .",
    "smoke": "tsx scripts/smoke-test.ts",
    "audit:security": "npm audit --omit=dev --audit-level=high && npm audit --audit-level=critical",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:import-legacy": "tsx src/db/import-legacy-sqlite.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "better-sqlite3": "^11.8.2",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.0",
    "lucide-react": "^0.475.0",
    "next": "^16.1.6",
    "openai": "^4.86.0",
    "plaid": "^41.4.0",
    "postgres": "^3.4.9",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-plaid-link": "^4.1.0",
    "recharts": "^2.15.0",
    "tailwind-merge": "^3.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.24.0",
    "eslint-config-next": "^16.1.6",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
